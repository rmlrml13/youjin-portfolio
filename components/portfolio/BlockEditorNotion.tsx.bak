'use client'
// components/portfolio/BlockEditorNotion.tsx
// Notion 스타일 블록 에디터
// - 각 블록이 독립적인 행 (클릭해서 편집)
// - 빈 블록에서 '/' 입력 → 블록 타입 선택 메뉴
// - 왼쪽 핸들(⠿)로 드래그 순서 변경
// - Enter → 새 블록, Backspace(빈 블록) → 위 블록으로 병합
// - flush() 호출 시 전체 저장

import {
  useState, useEffect, useRef, useImperativeHandle, forwardRef, useCallback,
} from 'react'
import type { ProjectBlock } from '@/lib/types'
import { COLORS } from '@/components/admin/adminStyles'

export interface BlockEditorHandle { flush: () => Promise<void> }

type BlockType = ProjectBlock['type']

interface NBlock {
  localId: string          // 로컬 고유 ID (React key)
  dbId: number | null      // DB id (null = 아직 미저장)
  type: BlockType
  content: string          // 텍스트/제목 HTML, video = URL
  image_url: string        // 이미지 블록
  sort_order: number
}

interface Props {
  projectId: number
  token: string
  apiBase?: string
  onBlocksChange?: (blocks: ProjectBlock[]) => void
}

let localIdCounter = 0
function newLocalId() { return `loc_${++localIdCounter}` }

function makeBlock(type: BlockType, partial: Partial<NBlock> = {}): NBlock {
  return { localId: newLocalId(), dbId: null, type, content: '', image_url: '', sort_order: 0, ...partial }
}

/* ── 블록 타입 메뉴 항목 ── */
const BLOCK_MENU = [
  { type: 'text'    as BlockType, icon: '¶', label: '텍스트',   desc: '일반 본문 텍스트' },
  { type: 'heading' as BlockType, icon: 'H', label: '제목',     desc: '굵은 섹션 제목' },
  { type: 'image'   as BlockType, icon: '🖼', label: '이미지',  desc: '사진 업로드' },
  { type: 'video'   as BlockType, icon: '▶', label: '동영상',  desc: 'YouTube / Vimeo / 파일' },
  { type: 'divider' as BlockType, icon: '—', label: '구분선',  desc: '수평선으로 구분' },
]

/* ─────────────────────────────────────────── */
const BlockEditorNotion = forwardRef<BlockEditorHandle, Props>(function BlockEditorNotion(
  { projectId, token, apiBase = '/api/projects', onBlocksChange }, ref
) {
  const [blocks,   setBlocks]   = useState<NBlock[]>([makeBlock('text')])
  const [loading,  setLoading]  = useState(true)
  const [flushing, setFlushing] = useState(false)
  const [focusId,  setFocusId]  = useState<string | null>(null)
  const [menu,     setMenu]     = useState<{ localId: string; x: number; y: number; query: string } | null>(null)
  const [menuIdx,  setMenuIdx]  = useState(0)
  const [dragId,   setDragId]   = useState<string | null>(null)
  const [dragOver, setDragOver] = useState<string | null>(null)

  const blocksRef   = useRef<NBlock[]>([])
  const imgInputRef = useRef<HTMLInputElement>(null)
  const vidInputRef = useRef<HTMLInputElement>(null)
  const pendingImgId = useRef<string | null>(null)
  const pendingVidId = useRef<string | null>(null)
  const editRefs    = useRef<Record<string, HTMLDivElement | null>>({})
  const base = `${apiBase}/${projectId}/blocks`

  /* ── 로드 ── */
  useEffect(() => { loadBlocks() }, [projectId])
  useEffect(() => {
    blocksRef.current = blocks
    onBlocksChange?.(blocks.filter(b => b.dbId != null).map(b => ({
      id: b.dbId!, type: b.type, content: b.content,
      image_url: b.image_url, sort_order: b.sort_order,
    })))
  }, [blocks])

  async function loadBlocks() {
    setLoading(true)
    const res  = await fetch(base)
    const data = await res.json()
    if (Array.isArray(data) && data.length > 0) {
      const loaded = data.map((b: ProjectBlock): NBlock => ({
        localId: newLocalId(), dbId: b.id, type: b.type,
        content: b.content, image_url: b.image_url, sort_order: b.sort_order,
      }))
      setBlocks(loaded)
    } else {
      setBlocks([makeBlock('text')])
    }
    setLoading(false)
  }

  /* ── flush ── */
  useImperativeHandle(ref, () => ({
    async flush() {
      setFlushing(true)
      const cur = blocksRef.current

      // 1) text/heading/divider 전부 삭제 후 재삽입
      await fetch(base, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } })

      const saved = await Promise.all(cur.map(async (b, i): Promise<NBlock> => {
        // 미디어는 sort_order만 업데이트
        if (b.type === 'image' || b.type === 'video') {
          if (b.dbId != null) {
            await fetch(`${base}/${b.dbId}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
              body: JSON.stringify({ sort_order: i }),
            })
          }
          return { ...b, sort_order: i }
        }
        // 빈 텍스트 스킵
        const text = b.content.replace(/<[^>]+>/g, '').trim()
        if (b.type === 'text' && !text) return { ...b, dbId: null, sort_order: i }

        const res = await fetch(base, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
          body: JSON.stringify({ type: b.type, content: b.content, sort_order: i }),
        })
        if (res.ok) { const d = await res.json(); return { ...b, dbId: d.id, sort_order: i } }
        return { ...b, sort_order: i }
      }))

      blocksRef.current = saved
      setBlocks(saved)
      setFlushing(false)
    }
  }))

  /* ── 블록 업데이트 헬퍼 ── */
  function updateBlock(localId: string, patch: Partial<NBlock>) {
    setBlocks(bs => bs.map(b => b.localId === localId ? { ...b, ...patch } : b))
  }
  function insertAfter(localId: string, newBlock: NBlock) {
    setBlocks(bs => {
      const idx = bs.findIndex(b => b.localId === localId)
      const next = [...bs]; next.splice(idx + 1, 0, newBlock); return next
    })
    setTimeout(() => {
      editRefs.current[newBlock.localId]?.focus()
      setFocusId(newBlock.localId)
    }, 20)
  }
  function removeBlock(localId: string) {
    setBlocks(bs => {
      if (bs.length === 1) return [makeBlock('text')]
      return bs.filter(b => b.localId !== localId)
    })
  }
  function focusPrev(localId: string) {
    const bs = blocksRef.current
    const idx = bs.findIndex(b => b.localId === localId)
    if (idx > 0) {
      const prev = bs[idx - 1]
      if (prev.type === 'text' || prev.type === 'heading') {
        setTimeout(() => {
          const el = editRefs.current[prev.localId]
          if (el) { el.focus(); const r = document.createRange(); r.selectNodeContents(el); r.collapse(false); window.getSelection()?.removeAllRanges(); window.getSelection()?.addRange(r) }
        }, 10)
      }
    }
  }

  /* ── 블록 타입 메뉴 닫기 ── */
  useEffect(() => {
    function handler(e: MouseEvent) {
      const target = e.target as HTMLElement
      if (!target.closest('.nbe-menu')) setMenu(null)
    }
    document.addEventListener('mousedown', handler)
    return () => document.removeEventListener('mousedown', handler)
  }, [])

  /* ── contenteditable 키다운 핸들러 ── */
  function handleKeyDown(e: React.KeyboardEvent<HTMLDivElement>, block: NBlock) {
    const el = e.currentTarget
    const text = el.innerText

    // 메뉴 열린 상태
    if (menu && menu.localId === block.localId) {
      const filtered = getFilteredMenu()
      if (e.key === 'ArrowDown') { e.preventDefault(); setMenuIdx(i => Math.min(i + 1, filtered.length - 1)); return }
      if (e.key === 'ArrowUp')   { e.preventDefault(); setMenuIdx(i => Math.max(i - 1, 0)); return }
      if (e.key === 'Enter')     { e.preventDefault(); applyMenuType(block.localId, filtered[menuIdx]?.type); return }
      if (e.key === 'Escape')    { setMenu(null); return }
      return
    }

    // / → 메뉴 열기 (빈 블록에서만)
    if (e.key === '/' && text.trim() === '') {
      e.preventDefault()
      const rect = el.getBoundingClientRect()
      setMenu({ localId: block.localId, x: rect.left, y: rect.bottom + 4, query: '' })
      setMenuIdx(0)
      return
    }

    // Enter → 새 블록 삽입
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault()
      const newB = makeBlock('text')
      insertAfter(block.localId, newB)
      return
    }

    // Backspace → 빈 블록 삭제
    if (e.key === 'Backspace' && text.trim() === '') {
      e.preventDefault()
      focusPrev(block.localId)
      if (block.dbId) fetch(`${base}/${block.dbId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } })
      removeBlock(block.localId)
      return
    }
  }

  function handleInput(e: React.FormEvent<HTMLDivElement>, block: NBlock) {
    const el = e.currentTarget
    const text = el.innerText
    // / 메뉴 query 업데이트
    if (menu && menu.localId === block.localId) {
      const after = text.slice(1)
      setMenu(m => m ? { ...m, query: after } : null)
      setMenuIdx(0)
    }
    updateBlock(block.localId, { content: el.innerHTML })
  }

  function getFilteredMenu() {
    if (!menu) return BLOCK_MENU
    return BLOCK_MENU.filter(item =>
      item.label.includes(menu.query) || item.type.includes(menu.query.toLowerCase())
    )
  }

  function applyMenuType(localId: string, type?: BlockType) {
    if (!type) return
    setMenu(null)
    const el = editRefs.current[localId]
    if (el) { el.innerHTML = ''; el.focus() }

    if (type === 'image') {
      pendingImgId.current = localId
      imgInputRef.current?.click()
      // 이 블록은 image 블록으로 교체
      updateBlock(localId, { type: 'image', content: '' })
      return
    }
    if (type === 'video') {
      updateBlock(localId, { type: 'video', content: '' })
      return
    }
    if (type === 'divider') {
      updateBlock(localId, { type: 'divider', content: '' })
      // 구분선 뒤에 텍스트 블록 자동 추가
      const newB = makeBlock('text')
      setTimeout(() => insertAfter(localId, newB), 50)
      return
    }
    updateBlock(localId, { type })
    setTimeout(() => { editRefs.current[localId]?.focus() }, 20)
  }

  /* ── 이미지 업로드 ── */
  async function handleImageUpload(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0]; if (!file) return
    const localId = pendingImgId.current
    if (!localId) return
    const previewUrl = URL.createObjectURL(file)
    updateBlock(localId, { type: 'image', image_url: previewUrl })

    const fd = new FormData(); fd.append('image', file); fd.append('sort_order', '0')
    const res = await fetch(base, { method: 'POST', headers: { Authorization: `Bearer ${token}` }, body: fd })
    if (res.ok) {
      const saved = await res.json()
      updateBlock(localId, { dbId: saved.id, image_url: saved.image_url })
    }
    e.target.value = ''; pendingImgId.current = null
  }

  /* ── 동영상 업로드 ── */
  async function handleVideoUpload(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0]; if (!file) return
    const localId = pendingVidId.current
    if (!localId) return
    const previewUrl = URL.createObjectURL(file)
    updateBlock(localId, { type: 'video', content: previewUrl })

    const fd = new FormData(); fd.append('image', file)
    const upRes = await fetch('/api/upload?folder=videos', { method: 'POST', headers: { Authorization: `Bearer ${token}` }, body: fd })
    if (upRes.ok) {
      const { url } = await upRes.json()
      const res = await fetch(base, {
        method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ type: 'video', content: url, sort_order: 0 }),
      })
      if (res.ok) { const saved = await res.json(); updateBlock(localId, { dbId: saved.id, content: url }) }
    }
    e.target.value = ''; pendingVidId.current = null
  }

  /* ── 드래그 앤 드롭 ── */
  function handleDragStart(localId: string) { setDragId(localId) }
  function handleDragOver(e: React.DragEvent, localId: string) { e.preventDefault(); setDragOver(localId) }
  function handleDrop(targetId: string) {
    if (!dragId || dragId === targetId) { setDragId(null); setDragOver(null); return }
    setBlocks(bs => {
      const from = bs.findIndex(b => b.localId === dragId)
      const to   = bs.findIndex(b => b.localId === targetId)
      const next = [...bs]
      const [item] = next.splice(from, 1)
      next.splice(to, 0, item)
      return next
    })
    setDragId(null); setDragOver(null)
  }
  function handleDragEnd() { setDragId(null); setDragOver(null) }

  /* ── 이미지 블록 삭제 ── */
  async function deleteMediaBlock(block: NBlock) {
    if (block.dbId) await fetch(`${base}/${block.dbId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } })
    removeBlock(block.localId)
  }

  /* ── URL 동영상 저장 ── */
  async function confirmVideoUrl(block: NBlock, url: string) {
    if (!url.trim()) return
    const res = await fetch(base, {
      method: 'POST', headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
      body: JSON.stringify({ type: 'video', content: url, sort_order: 0 }),
    })
    if (res.ok) { const saved = await res.json(); updateBlock(block.localId, { dbId: saved.id, content: url }) }
    else updateBlock(block.localId, { content: url })
  }

  if (loading) return (
    <div style={{ padding: '3rem', textAlign: 'center' }}>
      <span style={{ display: 'inline-block', width: 14, height: 14, border: `2px solid ${COLORS.border}`, borderTopColor: COLORS.gold, borderRadius: '50%', animation: 'spin 0.6s linear infinite' }} />
    </div>
  )

  return (
    <div style={{ fontFamily: 'inherit', position: 'relative' }}>

      {/* 저장 인디케이터 */}
      {flushing && (
        <div style={{ display: 'flex', alignItems: 'center', gap: '0.4rem', marginBottom: '0.75rem' }}>
          <span style={{ width: 8, height: 8, borderRadius: '50%', display: 'inline-block', border: `1.5px solid ${COLORS.border}`, borderTopColor: COLORS.gold, animation: 'spin 0.6s linear infinite' }} />
          <span style={{ fontSize: '9px', color: COLORS.inkFaint, fontFamily: 'DM Mono, monospace', letterSpacing: '0.08em' }}>저장 중...</span>
        </div>
      )}

      {/* 블록 목록 */}
      <div style={{ display: 'flex', flexDirection: 'column', gap: 2 }}>
        {blocks.map(block => (
          <BlockRow
            key={block.localId}
            block={block}
            isFocused={focusId === block.localId}
            isDragging={dragId === block.localId}
            isDragOver={dragOver === block.localId}
            editRef={el => { editRefs.current[block.localId] = el }}
            onFocus={() => setFocusId(block.localId)}
            onBlur={() => setFocusId(prev => prev === block.localId ? null : prev)}
            onKeyDown={e => handleKeyDown(e, block)}
            onInput={e => handleInput(e, block)}
            onDelete={() => {
              if (block.dbId) fetch(`${base}/${block.dbId}`, { method: 'DELETE', headers: { Authorization: `Bearer ${token}` } })
              removeBlock(block.localId)
            }}
            onDragStart={() => handleDragStart(block.localId)}
            onDragOver={e => handleDragOver(e, block.localId)}
            onDrop={() => handleDrop(block.localId)}
            onDragEnd={handleDragEnd}
            onAddBelow={() => insertAfter(block.localId, makeBlock('text'))}
            onImageUploadClick={() => { pendingImgId.current = block.localId; imgInputRef.current?.click() }}
            onVideoFileClick={() => { pendingVidId.current = block.localId; vidInputRef.current?.click() }}
            onVideoUrlConfirm={url => confirmVideoUrl(block, url)}
            onMediaDelete={() => deleteMediaBlock(block)}
          />
        ))}
      </div>

      {/* 하단 클릭 → 새 블록 추가 */}
      <div
        onClick={() => {
          const last = blocks[blocks.length - 1]
          if (last && (last.type === 'text' || last.type === 'heading') && !last.content.trim()) {
            editRefs.current[last.localId]?.focus(); return
          }
          const nb = makeBlock('text'); insertAfter(blocks[blocks.length - 1].localId, nb)
        }}
        style={{ height: 48, cursor: 'text', display: 'flex', alignItems: 'center', paddingLeft: 44, opacity: 0, transition: 'opacity 0.15s' }}
        onMouseEnter={e => (e.currentTarget.style.opacity = '1')}
        onMouseLeave={e => (e.currentTarget.style.opacity = '0')}
      >
        <span style={{ fontSize: '11px', color: COLORS.inkFaint, fontFamily: 'DM Mono, monospace', letterSpacing: '0.06em' }}>
          + 새 블록 추가 (클릭 또는 Enter)
        </span>
      </div>

      {/* / 명령어 메뉴 */}
      {menu && (() => {
        const filtered = getFilteredMenu()
        return (
          <div
            className="nbe-menu"
            style={{
              position: 'fixed', left: menu.x, top: menu.y, zIndex: 500,
              background: '#fff', border: `1px solid ${COLORS.border}`,
              borderRadius: 8, boxShadow: '0 8px 32px rgba(0,0,0,0.14)',
              padding: '0.4rem', minWidth: 220, overflow: 'hidden',
            }}
          >
            <p style={{ fontSize: '9px', letterSpacing: '0.14em', textTransform: 'uppercase', color: COLORS.inkFaint, padding: '0.3rem 0.75rem 0.5rem', fontFamily: 'DM Mono, monospace' }}>
              블록 타입 선택
            </p>
            {filtered.length === 0 && (
              <p style={{ padding: '0.5rem 0.75rem', fontSize: '12px', color: COLORS.inkFaint }}>결과 없음</p>
            )}
            {filtered.map((item, idx) => (
              <button
                key={item.type}
                onMouseDown={e => { e.preventDefault(); applyMenuType(menu.localId, item.type) }}
                style={{
                  display: 'flex', alignItems: 'center', gap: '0.75rem', width: '100%',
                  padding: '0.55rem 0.75rem', border: 'none', borderRadius: 5,
                  background: idx === menuIdx ? COLORS.hover : 'transparent',
                  cursor: 'pointer', textAlign: 'left', transition: 'background 0.1s',
                }}
                onMouseEnter={() => setMenuIdx(idx)}
              >
                <span style={{
                  width: 32, height: 32, background: COLORS.surface, border: `1px solid ${COLORS.border}`,
                  borderRadius: 6, display: 'flex', alignItems: 'center', justifyContent: 'center',
                  fontSize: '14px', flexShrink: 0, fontFamily: 'DM Serif Display, serif',
                }}>{item.icon}</span>
                <span style={{ display: 'flex', flexDirection: 'column', gap: '1px' }}>
                  <span style={{ fontSize: '13px', color: COLORS.ink, fontWeight: 500 }}>{item.label}</span>
                  <span style={{ fontSize: '10px', color: COLORS.inkFaint, fontFamily: 'DM Mono, monospace' }}>{item.desc}</span>
                </span>
              </button>
            ))}
          </div>
        )
      })()}

      <input ref={imgInputRef} type="file" accept="image/*" style={{ display: 'none' }} onChange={handleImageUpload} />
      <input ref={vidInputRef} type="file" accept="video/*" style={{ display: 'none' }} onChange={handleVideoUpload} />

      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        .nbe-block-row { transition: background 0.1s; }
        .nbe-block-row:hover .nbe-handle { opacity: 1 !important; }
        .nbe-block-row:hover .nbe-add-btn { opacity: 1 !important; }
      `}</style>
    </div>
  )
})

export default BlockEditorNotion

/* ═══════════════════════════════════════
   BlockRow — 단일 블록 행
═══════════════════════════════════════ */
interface BlockRowProps {
  block: NBlock
  isFocused: boolean
  isDragging: boolean
  isDragOver: boolean
  editRef: (el: HTMLDivElement | null) => void
  onFocus: () => void
  onBlur: () => void
  onKeyDown: (e: React.KeyboardEvent<HTMLDivElement>) => void
  onInput: (e: React.FormEvent<HTMLDivElement>) => void
  onDelete: () => void
  onDragStart: () => void
  onDragOver: (e: React.DragEvent) => void
  onDrop: () => void
  onDragEnd: () => void
  onAddBelow: () => void
  onImageUploadClick: () => void
  onVideoFileClick: () => void
  onVideoUrlConfirm: (url: string) => void
  onMediaDelete: () => void
}

function BlockRow({
  block, isFocused, isDragging, isDragOver,
  editRef, onFocus, onBlur, onKeyDown, onInput,
  onDelete, onDragStart, onDragOver, onDrop, onDragEnd, onAddBelow,
  onImageUploadClick, onVideoFileClick, onVideoUrlConfirm, onMediaDelete,
}: BlockRowProps) {
  const [urlInput, setUrlInput] = useState('')
  const [urlMode,  setUrlMode]  = useState(false)
  const [imgHover, setImgHover] = useState(false)

  const isText  = block.type === 'text' || block.type === 'heading'
  const isEmpty = isText && !block.content.trim()

  return (
    <div
      className="nbe-block-row"
      draggable
      onDragStart={onDragStart}
      onDragOver={onDragOver}
      onDrop={onDrop}
      onDragEnd={onDragEnd}
      style={{
        display: 'flex', alignItems: 'flex-start', gap: '6px',
        padding: '2px 0',
        borderRadius: 4,
        background: isDragOver ? '#F0F0EE' : isDragging ? '#FAFAF8' : 'transparent',
        borderLeft: isDragOver ? `2px solid ${COLORS.gold}` : '2px solid transparent',
        opacity: isDragging ? 0.5 : 1,
        transition: 'all 0.12s',
      }}
    >
      {/* 왼쪽 컨트롤: 핸들 + + 버튼 */}
      <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', paddingTop: 6, flexShrink: 0, width: 36, gap: 1 }}>
        {/* + 버튼 */}
        <button
          className="nbe-add-btn"
          onClick={onAddBelow}
          title="아래에 블록 추가"
          style={{
            opacity: 0, width: 18, height: 18, border: `1px solid ${COLORS.border}`,
            background: '#fff', borderRadius: 3, cursor: 'pointer', color: COLORS.inkMid,
            fontSize: '12px', lineHeight: 1, display: 'flex', alignItems: 'center', justifyContent: 'center',
            transition: 'all 0.1s', flexShrink: 0,
          }}
          onMouseEnter={e => { e.currentTarget.style.background = COLORS.hover; e.currentTarget.style.borderColor = COLORS.inkLight }}
          onMouseLeave={e => { e.currentTarget.style.background = '#fff'; e.currentTarget.style.borderColor = COLORS.border }}
        >+</button>
        {/* 드래그 핸들 */}
        <div
          className="nbe-handle"
          title="드래그하여 순서 변경"
          style={{
            opacity: 0, cursor: 'grab', color: COLORS.inkFaint, fontSize: '14px',
            lineHeight: 1, padding: '2px', userSelect: 'none', transition: 'opacity 0.1s',
          }}
        >⠿</div>
      </div>

      {/* 블록 본문 */}
      <div style={{ flex: 1, minWidth: 0, paddingRight: '0.5rem' }}>

        {/* 텍스트 / 제목 */}
        {isText && (
          <div
            ref={editRef}
            contentEditable
            suppressContentEditableWarning
            onFocus={onFocus}
            onBlur={e => { onBlur(); /* innerHTML sync */ }}
            onKeyDown={onKeyDown}
            onInput={onInput}
            data-placeholder={
              block.type === 'heading' ? '제목을 입력하세요...' :
              isFocused ? "내용을 입력하거나 '/'로 블록 타입을 선택하세요" : ''
            }
            style={{
              outline: 'none',
              minHeight: block.type === 'heading' ? '2rem' : '1.7rem',
              fontSize: block.type === 'heading' ? '1.45rem' : '15px',
              fontFamily: block.type === 'heading' ? 'DM Serif Display, serif' : 'inherit',
              fontWeight: block.type === 'heading' ? 700 : 400,
              lineHeight: block.type === 'heading' ? 1.25 : 1.8,
              color: COLORS.ink,
              padding: '4px 6px',
              borderRadius: 3,
              background: isFocused ? 'rgba(0,0,0,0.015)' : 'transparent',
              transition: 'background 0.1s',
              wordBreak: 'break-word',
            }}
          />
        )}

        {/* 이미지 블록 */}
        {block.type === 'image' && (
          <div style={{ padding: '4px 6px' }}>
            {block.image_url ? (
              <div
                style={{ position: 'relative', display: 'inline-block', width: '100%' }}
                onMouseEnter={() => setImgHover(true)}
                onMouseLeave={() => setImgHover(false)}
              >
                <img src={block.image_url} alt="" style={{ width: '100%', display: 'block', borderRadius: 4, border: `1px solid ${COLORS.border}` }} />
                {imgHover && (
                  <div style={{ position: 'absolute', top: 8, right: 8, display: 'flex', gap: 4 }}>
                    <button onClick={onImageUploadClick} style={mediaBtn}>변경</button>
                    <button onClick={onMediaDelete} style={{ ...mediaBtn, background: 'rgba(0,0,0,0.65)' }}>✕ 삭제</button>
                  </div>
                )}
              </div>
            ) : (
              <div
                onClick={onImageUploadClick}
                style={{
                  border: `2px dashed ${COLORS.borderMid}`, borderRadius: 4,
                  padding: '2rem', textAlign: 'center', cursor: 'pointer',
                  background: COLORS.surface, transition: 'all 0.15s',
                }}
                onMouseEnter={e => (e.currentTarget.style.borderColor = COLORS.inkLight)}
                onMouseLeave={e => (e.currentTarget.style.borderColor = COLORS.borderMid)}
              >
                <div style={{ fontSize: '1.5rem', marginBottom: '0.5rem' }}>🖼</div>
                <p style={{ fontSize: '12px', color: COLORS.inkMid }}>클릭하여 이미지 업로드</p>
              </div>
            )}
          </div>
        )}

        {/* 동영상 블록 */}
        {block.type === 'video' && (
          <div style={{ padding: '4px 6px' }}>
            {block.content ? (
              <div style={{ position: 'relative' }}
                onMouseEnter={() => setImgHover(true)}
                onMouseLeave={() => setImgHover(false)}
              >
                <VideoPlayer src={block.content} />
                {imgHover && (
                  <div style={{ position: 'absolute', top: 8, right: 8, display: 'flex', gap: 4 }}>
                    <button onClick={onMediaDelete} style={{ ...mediaBtn, background: 'rgba(0,0,0,0.65)' }}>✕ 삭제</button>
                  </div>
                )}
              </div>
            ) : (
              <div style={{ border: `1px solid ${COLORS.border}`, borderRadius: 4, padding: '1.25rem', background: COLORS.surface }}>
                <p style={{ fontSize: '12px', color: COLORS.inkMid, marginBottom: '0.75rem', fontFamily: 'DM Mono, monospace' }}>동영상 추가</p>
                <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' }}>
                  {/* URL 입력 */}
                  {urlMode ? (
                    <>
                      <input
                        autoFocus
                        placeholder="YouTube / Vimeo URL..."
                        value={urlInput}
                        onChange={e => setUrlInput(e.target.value)}
                        onKeyDown={e => { if (e.key === 'Enter') { onVideoUrlConfirm(urlInput); setUrlMode(false) } if (e.key === 'Escape') setUrlMode(false) }}
                        style={{ flex: 1, padding: '0.5rem 0.75rem', border: `1px solid ${COLORS.border}`, borderRadius: 3, fontSize: '12px', fontFamily: 'DM Mono, monospace', outline: 'none', minWidth: 0 }}
                      />
                      <button onClick={() => { onVideoUrlConfirm(urlInput); setUrlMode(false) }}
                        style={{ padding: '0.5rem 1rem', background: COLORS.ink, color: '#fff', border: 'none', borderRadius: 3, fontSize: '11px', cursor: 'pointer', fontFamily: 'DM Mono, monospace' }}>확인</button>
                      <button onClick={() => setUrlMode(false)}
                        style={{ padding: '0.5rem 0.6rem', background: 'transparent', color: COLORS.inkMid, border: `1px solid ${COLORS.border}`, borderRadius: 3, fontSize: '11px', cursor: 'pointer' }}>✕</button>
                    </>
                  ) : (
                    <>
                      <VidBtn onClick={() => setUrlMode(true)}>🔗 URL 입력</VidBtn>
                      <VidBtn onClick={onVideoFileClick}>📁 파일 업로드</VidBtn>
                    </>
                  )}
                </div>
              </div>
            )}
          </div>
        )}

        {/* 구분선 블록 */}
        {block.type === 'divider' && (
          <div style={{ padding: '12px 6px', display: 'flex', alignItems: 'center', gap: '0.5rem' }}>
            <hr style={{ flex: 1, border: 'none', borderTop: `1px solid ${COLORS.borderMid}` }} />
          </div>
        )}
      </div>

      {/* 오른쪽: 블록 타입 뱃지 + 삭제 */}
      <div style={{ display: 'flex', alignItems: 'center', gap: 4, paddingTop: 6, flexShrink: 0, opacity: isFocused ? 1 : 0, transition: 'opacity 0.15s' }}>
        <span style={{
          fontSize: '9px', letterSpacing: '0.1em', textTransform: 'uppercase',
          color: COLORS.inkFaint, fontFamily: 'DM Mono, monospace',
          background: COLORS.surface, border: `1px solid ${COLORS.border}`,
          padding: '2px 6px', borderRadius: 3,
        }}>{block.type}</span>
        <button
          onClick={onDelete}
          title="블록 삭제"
          style={{
            width: 20, height: 20, border: 'none', background: 'transparent',
            color: COLORS.inkFaint, cursor: 'pointer', fontSize: '12px',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            borderRadius: 3, transition: 'all 0.1s',
          }}
          onMouseEnter={e => { e.currentTarget.style.background = COLORS.redLight; e.currentTarget.style.color = COLORS.red }}
          onMouseLeave={e => { e.currentTarget.style.background = 'transparent'; e.currentTarget.style.color = COLORS.inkFaint }}
        >✕</button>
      </div>
    </div>
  )
}

/* ── 동영상 플레이어 ── */
function VideoPlayer({ src }: { src: string }) {
  const embedUrl = getEmbedUrl(src)
  if (embedUrl) {
    return (
      <div style={{ aspectRatio: '16/9', borderRadius: 4, overflow: 'hidden', background: '#000', border: `1px solid ${COLORS.border}` }}>
        <iframe src={embedUrl} style={{ width: '100%', height: '100%', border: 'none' }} allowFullScreen />
      </div>
    )
  }
  return (
    <div style={{ aspectRatio: '16/9', borderRadius: 4, overflow: 'hidden', background: '#000', border: `1px solid ${COLORS.border}` }}>
      <video src={src} controls style={{ width: '100%', height: '100%', objectFit: 'contain' }} />
    </div>
  )
}

/* ── 스타일 헬퍼 ── */
const mediaBtn: React.CSSProperties = {
  padding: '4px 10px', background: 'rgba(0,0,0,0.55)', color: '#fff',
  border: 'none', borderRadius: 3, fontSize: '10px', cursor: 'pointer',
  fontFamily: 'DM Mono, monospace',
}

function VidBtn({ children, onClick }: { children: React.ReactNode; onClick: () => void }) {
  return (
    <button onClick={onClick} style={{
      padding: '0.45rem 0.9rem', background: '#fff',
      border: `1px solid ${COLORS.border}`, borderRadius: 3,
      fontSize: '11px', color: COLORS.inkMid, cursor: 'pointer',
      fontFamily: 'DM Mono, monospace', transition: 'all 0.1s',
    }}
      onMouseEnter={e => { e.currentTarget.style.borderColor = COLORS.inkLight; e.currentTarget.style.color = COLORS.ink }}
      onMouseLeave={e => { e.currentTarget.style.borderColor = COLORS.border; e.currentTarget.style.color = COLORS.inkMid }}
    >{children}</button>
  )
}

function getEmbedUrl(url: string): string | null {
  if (!url) return null
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([\w-]{11})/)
  if (yt) return `https://www.youtube.com/embed/${yt[1]}?rel=0`
  const vm = url.match(/vimeo\.com\/(?:video\/)?([0-9]+)/)
  if (vm) return `https://player.vimeo.com/video/${vm[1]}`
  return null
}
